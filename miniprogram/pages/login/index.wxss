.container {
  padding: 40rpx;
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.form-box {
  width: 100%;
  padding: 0 40rpx;
}

.input-group {
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  font-size: 32rpx;
  height: 60rpx;
}

.captcha-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 10rpx;
  margin-bottom: 40rpx;
}

.captcha-group .label {
  width: auto;
  margin-right: 20rpx;
  margin-bottom: 0;
}

.captcha-input {
  flex: 1;
}

.captcha-img {
  width: 200rpx;
  height: 80rpx;
  margin-left: 20rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
}

.captcha-placeholder {
  width: 200rpx;
  height: 80rpx;
  margin-left: 20rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 24rpx;
  border-radius: 4rpx;
}

.btn-login {
  margin-top: 60rpx;
  background-color: #007aff;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-login:active {
  opacity: 0.9;
}

.footer {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.copyright {
  font-size: 24rpx;
  color: #ccc;
}
