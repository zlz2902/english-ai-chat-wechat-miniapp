.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.scenario-card {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.scenario-image {
  width: 100%;
  height: 300rpx;
  background-color: #eee;
}

.scenario-info {
  padding: 30rpx;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.scenario-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.scenario-level {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.scenario-level.easy {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.scenario-level.medium {
  background-color: #fff3e0;
  color: #ef6c00;
}

.scenario-level.hard {
  background-color: #ffebee;
  color: #c62828;
}

.scenario-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 25rpx;
  line-height: 1.5;
}

.btn-start {
  width: 100%;
  background-color: #007AFF;
  color: white;
  font-weight: normal;
  border-radius: 40rpx;
}
