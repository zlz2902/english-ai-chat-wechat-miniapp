<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{totalDays}}</text>
      <text class="stat-desc">累计打卡(天)</text>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{missedDays}}</text>
      <text class="stat-desc">本月缺卡(次)</text>
    </view>
  </view>

  <!-- 日历区域 -->
  <view class="calendar-card">
    <view class="calendar-header">
      <view class="arrow-btn" bindtap="prevMonth">◀</view>
      <text class="current-date">{{year}}年{{month}}月</text>
      <view class="arrow-btn" bindtap="nextMonth">▶</view>
    </view>

    <!-- 星期表头 -->
    <view class="week-header">
      <view wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="week-item">{{item}}</view>
    </view>

    <!-- 日期格子 -->
    <view class="days-grid">
      <view wx:for="{{calendarDays}}" wx:key="date" class="day-cell">
        <view class="day-num {{item.type}} {{item.isChecked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}}">
          {{item.day}}
        </view>
      </view>
    </view>
  </view>

  <!-- 打卡按钮 -->
  <button class="checkin-btn" bindtap="handleCheckin" disabled="{{hasCheckedInToday}}">
    {{hasCheckedInToday ? '今日已打卡' : '立即打卡'}}
  </button>
</view>
