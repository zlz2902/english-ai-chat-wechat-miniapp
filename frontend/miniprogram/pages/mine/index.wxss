.mine-container {
  min-height: 100vh;
  background-color: #f6f7f9;
  padding-bottom: 40rpx;
}

/* Header */
.user-header {
  background: white;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #00C6FF 0%, #0072FF 100%);
  padding: 40rpx;
  border-radius: 24rpx;
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(0, 114, 255, 0.2);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
  background-color: #f0f0f0;
}

.info-box {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.9;
  background: rgba(0, 0, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  align-self: flex-start;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.edit-icon {
  font-size: 36rpx;
  opacity: 0.8;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* Menu Groups */
.menu-group {
  background: white;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 110rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  opacity: 0.8;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* Logout Button */
.logout-box {
  padding: 40rpx 30rpx;
}

.btn-logout {
  background: white;
  color: #ff3b30;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx 0;
  line-height: 1.5;
}

.btn-logout::after {
  border: none;
}