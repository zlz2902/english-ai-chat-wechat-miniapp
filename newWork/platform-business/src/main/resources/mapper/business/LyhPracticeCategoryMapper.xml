<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.horzits.business.mapper.LyhPracticeCategoryMapper">
    
    <resultMap type="com.horzits.business.domain.LyhPracticeCategory" id="LyhPracticeCategoryResult">
        <result property="categoryId"    column="category_id"    />
        <result property="categoryName"  column="category_name"  />
        <result property="categoryType"  column="category_type"  />
        <result property="sortOrder"     column="sort_order"     />
        <result property="status"        column="status"         />
        <result property="delFlag"       column="del_flag"       />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectLyhPracticeCategoryVo">
        select category_id, category_name, category_type, sort_order, status, del_flag, create_by, create_time, update_by, update_time, remark 
        from lyh_practice_category
    </sql>

    <select id="selectLyhPracticeCategoryList" parameterType="com.horzits.business.domain.LyhPracticeCategory" resultMap="LyhPracticeCategoryResult">
        <include refid="selectLyhPracticeCategoryVo"/>
        <where>  
            <if test="delFlag != null and delFlag != ''"> and del_flag = #{delFlag}</if>
            <if test="categoryName != null  and categoryName != ''"> and category_name like concat('%', #{categoryName}, '%')</if>
            <if test="categoryType != null  and categoryType != ''"> and category_type = #{categoryType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by sort_order asc, category_id asc
    </select>
    
    <select id="selectLyhPracticeCategoryByCategoryId" parameterType="Long" resultMap="LyhPracticeCategoryResult">
        <include refid="selectLyhPracticeCategoryVo"/>
        where category_id = #{categoryId}
    </select>
        
    <insert id="insertLyhPracticeCategory" parameterType="com.horzits.business.domain.LyhPracticeCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into lyh_practice_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryType != null and categoryType != ''">category_type,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryType != null and categoryType != ''">#{categoryType},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateLyhPracticeCategory" parameterType="com.horzits.business.domain.LyhPracticeCategory">
        update lyh_practice_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryType != null and categoryType != ''">category_type = #{categoryType},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteLyhPracticeCategoryByCategoryId" parameterType="Long">
        delete from lyh_practice_category where category_id = #{categoryId}
    </delete>

    <delete id="deleteLyhPracticeCategoryByCategoryIds" parameterType="String">
        delete from lyh_practice_category where category_id in 
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>
</mapper>

